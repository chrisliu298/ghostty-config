# Window Settings
# window-width = 124
# window-height = 36
window-padding-x = 16
window-padding-y = 16
window-padding-balance = true
window-save-state = always
window-theme = system
confirm-close-surface = false
auto-update-channel = stable
resize-overlay = always
resize-overlay-duration = 750ms

# macOS-Specific Window Settings
macos-non-native-fullscreen = true
# macos-titlebar-style = tabs
macos-titlebar-style = transparent
macos-option-as-alt = true

# Appearance/Theme
# theme = Alabaster
# theme = GitHub Dark Dimmed Modified
theme = GitHub Dark
# background-opacity = 0.95
background-blur = 16
minimum-contrast = 1.1

# Font/Typography
font-family = Berkeley Mono
font-size = 18
font-thicken = true
bold-is-bright = false

# Cursor
cursor-color = #FFFFFF
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 4

# Cell/Display
adjust-cell-height = 10%
adjust-cell-width = -10%

# Scrollback
scrollback-limit = 134217728

# Links
link-url = true

# Keybindings
keybind = shift+enter=text:\x1b\r
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+arrow_left=goto_split:left
keybind = cmd+opt+arrow_right=goto_split:right
keybind = cmd+opt+arrow_up=goto_split:top
keybind = cmd+opt+arrow_down=goto_split:bottom
keybind = cmd+k=clear_screen
keybind = cmd+r=prompt_surface_title
keybind = cmd+shift+left=move_tab:-1
keybind = cmd+shift+right=move_tab:1
keybind = cmd+left=text:\x1b[H
keybind = cmd+right=text:\x1b[F

# Working Directory
working-directory = home
# window-inherit-working-directory = false

# Shell Integration
shell-integration = detect
shell-integration-features = sudo,ssh-terminfo,ssh-env

# Notifications
# desktop-notifications = true
# notify-on-command-finish = always
# notify-on-command-finish-action = no-bell,notify
