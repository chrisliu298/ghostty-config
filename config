# Window
window-padding-x = 16
window-padding-y = 16
window-padding-balance = true
window-save-state = always
window-theme = system
confirm-close-surface = false # tmux preserves sessions if needed
auto-update-channel = stable
resize-overlay = always
resize-overlay-duration = 750ms

# macOS
macos-non-native-fullscreen = true # avoids Space-switching animation
macos-titlebar-style = transparent
macos-option-as-alt = true # enables Alt keybinds; breaks macOS special chars

# Appearance
theme = GitHub Dark
# background-opacity = 0.95
background-blur = 16
minimum-contrast = 1.1

# Font
font-family = Berkeley Mono
font-size = 18
font-thicken = true
bold-is-bright = false # prevent bold from shifting to bright palette colors

# Cursor
cursor-color = #FFFFFF
cursor-style = bar
cursor-style-blink = false
adjust-cursor-thickness = 4 # thicker bar for visibility on HiDPI

# Cell
adjust-cell-height = 10% # taller lines + tighter chars for
adjust-cell-width = -10% # Berkeley Mono readability

# Scrollback
scrollback-limit = 134217728 # 128 MiB; effectively unlimited

# Links
link-url = true

# Keybindings
keybind = shift+enter=text:\x1b\r # send ESC+CR so apps detect Shift+Enter
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+arrow_left=goto_split:left
keybind = cmd+opt+arrow_right=goto_split:right
keybind = cmd+opt+arrow_up=goto_split:top
keybind = cmd+opt+arrow_down=goto_split:bottom
keybind = cmd+k=clear_screen
keybind = cmd+r=prompt_surface_title
keybind = cmd+shift+left=move_tab:-1
keybind = cmd+shift+right=move_tab:1
keybind = cmd+left=text:\x1b[H # Home (macOS has no dedicated key)
keybind = cmd+right=text:\x1b[F # End

# Working Directory
working-directory = home

# Shell Integration
shell-integration = detect
shell-integration-features = sudo,ssh-terminfo,ssh-env # cursor/title handled by prompt and tmux
